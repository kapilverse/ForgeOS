# ForgeOS server configuration.
# Copy to ".env" and adjust as needed. The server auto-loads .env if present.

# PostgreSQL connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://forgeos:forgeos@localhost:5432/forgeos?sslmode=disable

# Secret used to sign JWT auth tokens. CHANGE THIS in any real deployment.
# Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Address the ForgeOS API listens on.
LISTEN_ADDR=:8081

# Docker network that Traefik and every app container join.
# Must match the network name in docker-compose.yml.
DOCKER_NETWORK=forgeos

# Base domain used to generate <slug>.<FORGEOS_DOMAIN> hostnames.
FORGEOS_DOMAIN=forgeos.local

# CORS: comma-separated list of allowed origins. Use "*" to allow all.
CORS_ALLOWED_ORIGINS=*
